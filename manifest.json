{
  "manifest_version": 3,
  "name": "Script Keeper",
  "version": "1.3.0",
  "description": "Floating popup window with ticket macros.",
  "permissions": [
    "scripting",
    "tabs",
    "activeTab",
    "storage"
  ],
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Ticket Tool",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png"
    }
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["hotkeys.js"],
      "run_at": "document_idle"
    }
  ]
}